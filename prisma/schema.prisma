generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Note: Neon free tier with PgBouncer does NOT support prisma migrate (advisory locks).
  // Schema changes are applied via prisma db execute + SQL files in prisma/sql/
  // Then run: npx prisma generate (to update the client)
}

// ============================================
// SOURCES & MERCHANTS
// ============================================

model Source {
  id              String       @id @default(cuid())
  name            String // "Amazon Brasil", "Mercado Livre", etc.
  slug            String       @unique
  logoUrl         String?
  status          SourceStatus @default(ACTIVE)
  affiliateConfig Json? // Config específica por parceiro
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  merchants Merchant[]
  listings  Listing[]
  coupons   Coupon[]

  @@map("sources")
}

enum SourceStatus {
  ACTIVE
  PAUSED
  ERROR
  DISABLED
}

model Merchant {
  id         String   @id @default(cuid())
  sourceId   String
  externalId String?
  name       String
  slug       String
  rating     Float?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  source   Source    @relation(fields: [sourceId], references: [id])
  listings Listing[]

  @@unique([sourceId, externalId])
  @@map("merchants")
}

// ============================================
// CATALOG (canonical products)
// ============================================

model Category {
  id             String   @id @default(cuid())
  parentId       String?
  name           String
  slug           String   @unique
  icon           String?
  description    String?
  seoTitle       String?
  seoDescription String?
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("brands")
}

model Product {
  id              String        @id @default(cuid())
  brandId         String?
  categoryId      String?
  name            String
  slug            String        @unique
  description     String?
  imageUrl        String?
  images          String[] // array de URLs
  specsJson       Json?
  status          ProductStatus @default(ACTIVE)
  popularityScore Float         @default(0)
  featured        Boolean       @default(false)
  hidden          Boolean       @default(false)
  needsReview     Boolean       @default(false)
  editorialScore  Int?
  originType      String        @default("seed") // "seed" | "imported" | "manual" | "curated"
  discoverySource String? // "ml_discovery" | "ml_highlights" | "manual_import" | "csv_upload" | "admin"
  importedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  brand    Brand?           @relation(fields: [brandId], references: [id])
  category Category?        @relation(fields: [categoryId], references: [id])
  variants        ProductVariant[]
  listings        Listing[]
  reviewAggregate ReviewAggregate?
  userReviews     UserReview[]

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([popularityScore(sort: Desc)])
  @@index([originType])
  @@index([importedAt])
  @@index([status, popularityScore(sort: Desc)])
  @@index([status, originType])
  @@index([categoryId, status])
  @@index([brandId, status])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
  MERGED
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  variantName String
  color       String?
  size        String?
  storage     String?
  modelCode   String?
  gtin        String?
  specsJson   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@map("product_variants")
}

// ============================================
// LISTINGS & OFFERS (from sources)
// ============================================

model Listing {
  id                 String             @id @default(cuid())
  sourceId           String
  merchantId         String?
  productId          String?
  variantId          String?
  externalId         String
  rawTitle           String
  rawDescription     String?
  rawBrand           String?
  rawCategory        String?
  imageUrl           String?
  productUrl         String
  availability       AvailabilityStatus @default(IN_STOCK)
  rating             Float?
  reviewsCount       Int?
  salesCountEstimate Int?
  rawPayloadJson     Json?
  matchConfidence    Float? // 0-1 confidence of product match
  status             ListingStatus      @default(ACTIVE)
  lastSeenAt         DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  source      Source          @relation(fields: [sourceId], references: [id])
  merchant    Merchant?       @relation(fields: [merchantId], references: [id])
  product     Product?        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  offers      Offer[]
  priceAlerts PriceAlert[]

  @@unique([sourceId, externalId])
  @@index([productId])
  @@index([sourceId])
  @@index([status])
  @@index([status, sourceId])
  @@index([productId, status])
  @@index([status, lastSeenAt])
  @@map("listings")
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  UNMATCHED
}

enum AvailabilityStatus {
  IN_STOCK
  OUT_OF_STOCK
  PRE_ORDER
  UNKNOWN
}

model Offer {
  id              String   @id @default(cuid())
  listingId       String
  currentPrice    Float
  originalPrice   Float?
  couponText      String?
  shippingPrice   Float?
  installmentText String?
  isFreeShipping  Boolean  @default(false)
  isActive        Boolean  @default(true)
  offerScore      Float    @default(0)
  affiliateUrl    String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listing        Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  priceSnapshots PriceSnapshot[]
  clickouts      Clickout[]

  @@index([listingId])
  @@index([offerScore(sort: Desc)])
  @@index([isActive])
  @@index([currentPrice])
  @@index([isActive, offerScore(sort: Desc)])
  @@index([isActive, listingId])
  @@index([listingId, isActive, offerScore(sort: Desc)])
  @@map("offers")
}

model PriceSnapshot {
  id            String   @id @default(cuid())
  offerId       String
  price         Float
  originalPrice Float?
  capturedAt    DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, capturedAt])
  @@map("price_snapshots")
}

// ============================================
// COUPONS
// ============================================

model Coupon {
  id          String       @id @default(cuid())
  sourceId    String?
  code        String
  description String?
  startAt     DateTime?
  endAt       DateTime?
  rulesJson   Json?
  status      CouponStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  source Source? @relation(fields: [sourceId], references: [id])

  @@map("coupons")
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

// ============================================
// TRACKING & ANALYTICS
// ============================================

model Clickout {
  id           String   @id @default(cuid())
  offerId      String
  sourceSlug   String?
  clickedAt    DateTime @default(now())
  referrer     String?
  sessionId    String?
  query        String?
  categorySlug String?
  userAgent    String?
  originType   String? // "seed" | "imported" | "manual" | "curated"
  railSource   String? // "hot_offers" | "best_sellers" | "recently_imported" | "best_value" | "lowest_prices" | "deal_of_day" | "category" | "search" | "product"

  // Block-level tracking (commercial decision intelligence)
  blockId            String? // UI block: "price-comparison", "decision-summary", "recommendation", "hero", etc.
  positionInBlock    Int?    // 0-indexed position within the block
  recommendationType String? // "best-price" | "best-value" | "best-trust" | "best-shipping" | "best-rated" | "best-overall"
  ctaLabel           String? // Label shown to user on the CTA button

  // Attribution fields (persisted, no longer in-memory)
  pageType     String? // "home" | "search" | "product" | "category" | "brand" | "offer" | "guide" | "comparison" | "email" | "channel"
  channelOrigin String? // "direct" | "telegram" | "whatsapp" | "email" | "slack" | "discord" | "referral"
  campaignId   String?
  bannerId     String?
  productId    String? // product that was being viewed when clickout happened
  referralCode String?

  offer       Offer        @relation(fields: [offerId], references: [id])
  conversions Conversion[]

  @@index([offerId])
  @@index([clickedAt])
  @@index([sourceSlug])
  @@index([sourceSlug, clickedAt])
  @@index([offerId, clickedAt])
  @@index([pageType, clickedAt])
  @@index([channelOrigin, clickedAt])
  @@index([campaignId])
  @@map("clickouts")
}

model SearchLog {
  id               String   @id @default(cuid())
  query            String
  normalizedQuery  String?
  resultsCount     Int?
  clickedProductId String?
  createdAt        DateTime @default(now())

  @@index([normalizedQuery])
  @@index([createdAt])
  @@index([query])
  @@index([normalizedQuery, createdAt])
  @@map("search_logs")
}

// ============================================
// EDITORIAL & CURATION
// ============================================

model EditorialBlock {
  id          String          @id @default(cuid())
  blockType   EditorialType
  title       String
  slug        String          @unique
  subtitle    String?
  payloadJson Json?
  position    Int             @default(0)
  status      EditorialStatus @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("editorial_blocks")
}

enum EditorialType {
  HERO_BANNER
  RAIL
  GRID
  ARTICLE
  TOP_PICKS
  COUPON_WALL
}

enum EditorialStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// JOBS & SYSTEM
// ============================================

model JobRun {
  id         String    @id @default(cuid())
  jobName    String
  status     JobStatus @default(RUNNING)
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  durationMs Int?
  itemsTotal Int?
  itemsDone  Int?
  errorLog   String?
  metadata   Json?

  @@index([jobName, startedAt])
  @@map("job_runs")
}

enum JobStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

// ============================================
// GROWTH ACTIONS (Agent auto-execution)
// ============================================

model GrowthAction {
  id              String             @id @default(cuid())
  agentName       String             // e.g. "opportunity-agent"
  actionType      String             // e.g. "fill_hero_slot", "prepare_campaign"
  description     String
  priorityScore   Int                @default(50) // 0-100
  impactScore     Int                @default(50) // 0-100
  confidenceScore Int                @default(50) // 0-100
  status          GrowthActionStatus @default(SUGGESTED)
  autoApproved    Boolean            @default(false)
  guardrailsPassed String[]          // guardrails that were checked
  guardrailsFailed String[]          // guardrails that blocked
  result          Json?              // outcome data after execution
  errorLog        String?
  metadata        Json?
  createdAt       DateTime           @default(now())
  executedAt      DateTime?
  completedAt     DateTime?

  @@index([agentName, status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("growth_actions")
}

enum GrowthActionStatus {
  SUGGESTED
  APPROVED
  EXECUTING
  DONE
  FAILED
  SKIPPED
}

// ============================================
// PRICE ALERTS
// ============================================

model PriceAlert {
  id          String    @id @default(cuid())
  listingId   String
  email       String
  userId      String?
  targetPrice Float
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserAlerts", fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([isActive])
  @@index([listingId])
  @@index([email, isActive])
  @@index([isActive, listingId])
  @@index([userId])
  @@map("price_alerts")
}

// ============================================
// TRENDING KEYWORDS
// ============================================

model TrendingKeyword {
  id        String   @id @default(cuid())
  keyword   String
  url       String?
  position  Int      @default(0)
  fetchedAt DateTime @default(now())

  @@unique([keyword, fetchedAt])
  @@index([fetchedAt])
  @@index([keyword])
  @@map("trending_keywords")
}

// ============================================
// ARTICLES / CONTENT ENGINE
// ============================================

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  subtitle    String?
  content     String // markdown
  category    String?
  tags        String[]
  imageUrl    String?
  author      String        @default("PromoSnap")
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// REFERRALS
// ============================================

model Referral {
  id        String   @id @default(cuid())
  code      String   @unique
  email     String?
  visits    Int      @default(0)
  clickouts Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@map("referrals")
}

// ============================================
// NEWSLETTER SUBSCRIBERS
// ============================================

model Subscriber {
  id              String           @id @default(cuid())
  email           String           @unique
  phone           String?          // WhatsApp number (E.164 format)
  name            String?          // First name for personalisation
  status          SubscriberStatus @default(ACTIVE)
  source          String           @default("website")
  interests       String[]         // category slugs of interest
  tags            String[]         // segmentation tags: tech, bargain, gamer, etc.
  frequency       String           @default("weekly") // daily, weekly, monthly
  // Channel opt-in
  channelEmail    Boolean          @default(true)
  channelWhatsApp Boolean          @default(false)
  channelPush     Boolean          @default(false)
  // Engagement
  engagementScore Int              @default(0) // 0-100
  segment         String?          // tech_enthusiast, bargain_hunter, gamer, etc.
  lastActiveAt    DateTime?
  // Quiet hours (BRT)
  quietStart      Int?             // hour 0-23 (null = no preference)
  quietEnd        Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  messages CrmMessage[]

  @@index([status])
  @@index([source])
  @@index([phone])
  @@index([engagementScore])
  @@index([status, channelWhatsApp])
  @@map("subscribers")
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
}

// ============================================
// CRM — EVENTS, MESSAGES, QUEUE
// ============================================

model CrmEvent {
  id           String   @id @default(cuid())
  sessionId    String?
  email        String?
  eventType    String   // search, view_product, clickout, favorite, alert_create, compare, etc.
  payload      Json?    // { productId, query, category, source, price, ... }
  createdAt    DateTime @default(now())

  @@index([email, createdAt])
  @@index([email, eventType])
  @@index([eventType, createdAt])
  @@index([sessionId])
  @@map("crm_events")
}

model CrmMessage {
  id            String         @id @default(cuid())
  subscriberId  String
  channel       CrmChannel
  messageType   String         // alert_triggered, price_drop, weekly_digest, welcome, reengagement, etc.
  subject       String?
  body          String
  productId     String?
  offerId       String?
  status        CrmMsgStatus   @default(QUEUED)
  scheduledAt   DateTime?
  sentAt        DateTime?
  clickedAt     DateTime?
  errorMessage  String?
  // Quality gate metadata
  valueScore    Float          @default(0) // 0-100 — estimated value of sending this
  spamRiskScore Float          @default(0) // 0-100 — risk of being perceived as spam
  dedupKey      String?        // subscriberId:productId:messageType:window → idempotency
  aiGenerated   Boolean        @default(false)
  createdAt     DateTime       @default(now())

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([dedupKey])
  @@index([subscriberId, createdAt])
  @@index([status, scheduledAt])
  @@index([channel, status])
  @@index([messageType, createdAt])
  @@map("crm_messages")
}

enum CrmChannel {
  EMAIL
  WHATSAPP
  PUSH
  ONSITE
}

enum CrmMsgStatus {
  QUEUED
  SENT
  CLICKED
  FAILED
  SUPPRESSED // blocked by quality gate
}

// ============================================
// CONVERSIONS (affiliate postback tracking)
// ============================================

model Conversion {
  id            String           @id @default(cuid())
  clickoutId    String?
  source        String           // "amazon", "mercadolivre", "shopee", "shein"
  externalTxId  String?          // transaction ID from affiliate network
  subId         String?          // our clickout ID passed as sub_id
  orderValue    Float?           // gross order value (GMV)
  commission    Float?           // confirmed commission
  currency      String           @default("BRL")
  status        ConversionStatus @default(PENDING)
  postbackRaw   Json?            // raw postback payload for audit
  confirmedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  clickout Clickout? @relation(fields: [clickoutId], references: [id])

  @@unique([source, externalTxId])
  @@index([clickoutId])
  @@index([source, status])
  @@index([createdAt])
  @@index([status])
  @@map("conversions")
}

enum ConversionStatus {
  PENDING    // postback received, not yet confirmed
  CONFIRMED  // confirmed by affiliate network
  REJECTED   // rejected/cancelled
}

// ============================================
// EMAIL LOGS
// ============================================

model EmailLog {
  id       String   @id @default(cuid())
  to       String
  subject  String
  template String
  status   String   @default("sent")
  sentAt   DateTime @default(now())

  @@index([sentAt])
  @@index([template])
  @@map("email_logs")
}

// ============================================
// BANNERS
// ============================================

model Banner {
  id         String     @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String?
  ctaText    String?
  ctaUrl     String?
  bannerType BannerType @default(HERO)
  priority   Int        @default(0)
  isActive   Boolean    @default(true)
  startAt    DateTime?
  endAt      DateTime?
  autoMode   String? // "top-offers", "top-discount", "campaign", null=manual
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([isActive, bannerType, priority(sort: Desc)])
  @@map("banners")
}

enum BannerType {
  HERO
  MODAL
  STRIP
  CAROUSEL
}

// ============================================
// IMPORT BATCHES & CATALOG CANDIDATES
// ============================================

model ImportBatch {
  id          String       @id @default(cuid())
  fileName    String?
  format      String       @default("json") // json, csv
  status      ImportStatus @default(PENDING)
  totalItems  Int          @default(0)
  imported    Int          @default(0)
  rejected    Int          @default(0)
  errors      Json?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  candidates CatalogCandidate[]

  @@map("import_batches")
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CatalogCandidate {
  id            String          @id @default(cuid())
  importBatchId String?
  title         String
  brand         String?
  category      String?
  imageUrl      String?
  price         Float?
  originalPrice Float?
  affiliateUrl  String?
  sourceSlug    String?
  externalId    String?
  status        CandidateStatus @default(PENDING)
  enrichedData  Json?
  rejectionNote String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([status])
  @@index([importBatchId])
  @@map("catalog_candidates")
}

enum CandidateStatus {
  PENDING
  APPROVED
  REJECTED
  IMPORTED
}

// ============================================
// REVIEW AGGREGATES (cached consolidated reviews)
// ============================================

model ReviewAggregate {
  id            String   @id @default(cuid())
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Consolidated rating
  rating        Float    // 1-5 weighted average
  totalReviews  Int
  confidence    String   // high | medium | low | insufficient_data
  sourcesCount  Int

  // Structured themes (prepared for AI enrichment)
  themes        Json?    // ReviewTheme[] → [{ theme, polarity, strength, mentions, confidence }]

  // AI-generated summary cache
  aiSummary     Json?    // { summary, goodFor, considerIf, generatedAt }

  // Freshness
  dataFreshness String   @default("fresh") // fresh (<7d) | recent (<30d) | stale (>30d)
  lastUpdatedAt DateTime @default(now())

  @@index([confidence])
  @@index([rating(sort: Desc)])
  @@map("review_aggregates")
}

// ============================================
// SYSTEM SETTINGS (key-value store for ML OAuth tokens, etc.)
// ============================================

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ============================================
// AUTH — NextAuth.js compatible models
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  interests     String[]  // category slugs
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  reviews     UserReview[]
  alerts      PriceAlert[] @relation("UserAlerts")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// USER REVIEWS
// ============================================

model UserReview {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  // For anonymous reviews (no auth required)
  authorName  String?
  authorEmail String?
  // Review content
  rating    Int      // 1-5
  title     String?
  content   String?  @db.Text
  pros      String[] // "Bateria dura muito", "Camera excelente"
  cons      String[] // "Pesado", "Esquenta"
  verified  Boolean  @default(false) // true if user bought via PromoSnap
  status    ReviewStatus @default(PENDING)
  helpful   Int      @default(0) // "achei útil" counter
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, status])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@map("user_reviews")
}

enum ReviewStatus {
  PENDING   // awaiting moderation
  APPROVED  // visible to all
  REJECTED  // spam or inappropriate
}

// ============================================
// WHATSAPP BROADCAST
// ============================================

model WaChannel {
  id                  String   @id @default(cuid())
  name                String
  destinationId       String
  isActive            Boolean  @default(true)
  timezone            String   @default("America/Sao_Paulo")
  quietHoursStart     Int?
  quietHoursEnd       Int?
  dailyLimit          Int      @default(3)
  windowLimit         Int      @default(1)
  defaultOfferCount   Int      @default(5)
  groupType           String   @default("geral")
  tags                String[] @default([])
  categoriesInclude   String[] @default([])
  categoriesExclude   String[] @default([])
  marketplacesInclude String[] @default([])
  marketplacesExclude String[] @default([])
  templateMode        String   @default("radar")
  tonality            String   @default("curadoria")
  sentToday           Int      @default(0)
  lastSentAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  campaigns    WaCampaign[]
  deliveryLogs WaDeliveryLog[]

  @@index([isActive])
  @@map("wa_channels")
}

model WaCampaign {
  id                    String   @id @default(cuid())
  channelId             String
  name                  String
  campaignType          String   @default("scheduled")
  schedule              String?
  isActive              Boolean  @default(true)
  offerCount            Int      @default(5)
  minScore              Int      @default(50)
  minDiscount           Int?
  maxTicket             Float?
  minTicket             Float?
  categorySlugs         String[] @default([])
  marketplaces          String[] @default([])
  requireImage          Boolean  @default(true)
  requireAffiliate      Boolean  @default(true)
  prioritizeTopSellers  Boolean  @default(true)
  structureType         String   @default("radar")
  lastRunAt             DateTime?
  totalSent             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  channel      WaChannel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  deliveryLogs WaDeliveryLog[]

  @@index([channelId])
  @@index([isActive])
  @@map("wa_campaigns")
}

model WaDeliveryLog {
  id               String   @id @default(cuid())
  channelId        String
  channelName      String
  campaignId       String?
  campaignName     String?
  status           String   @default("queued")
  messageText      String
  offerIds         String[] @default([])
  offerCount       Int      @default(0)
  templateUsed     String?
  openingUsed      String?
  ctaUsed          String?
  providerResponse Json?
  errorMessage     String?
  dryRun           Boolean  @default(false)
  sentAt           DateTime?
  createdAt        DateTime @default(now())

  channel  WaChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  campaign WaCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([campaignId])
  @@index([sentAt(sort: Desc)])
  @@index([dryRun, status])
  @@map("wa_delivery_logs")
}

// ============================================
// PRICE INDEX — monthly market reports
// ============================================

model PriceIndex {
  id         String   @id @default(cuid())
  period     String   @unique // "2026-03", "2026-04"
  category   String   // "celulares", "notebooks", "all"
  avgPrice   Float
  minPrice   Float
  maxPrice   Float
  medianPrice Float
  productCount Int
  priceChange Float   // % change vs previous period
  topDeals   Json?    // top 5 deals of the period
  insights   Json?    // AI-generated insights
  createdAt  DateTime @default(now())

  @@index([period, category])
  @@map("price_indexes")
}

