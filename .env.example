# ============================================
# PromoSnap — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# Variables marked (required) must be set for the app to run.
# Variables marked (optional) enable extra features.

# ---- Database (required) ----
DATABASE_URL="postgresql://user:password@localhost:5432/promosnap?schema=public"
# REDIS_URL=""  # Optional — enables caching layer (ioredis)

# ---- App / Domain (required) ----
NEXT_PUBLIC_APP_URL="https://www.promosnap.com.br"
APP_URL="https://www.promosnap.com.br"
NEXT_PUBLIC_APP_NAME="PromoSnap"
# NEXT_PUBLIC_SITE_URL=""  # Alias for APP_URL (fallback)

# ---- Auth & Admin (required) ----
ADMIN_SECRET="change-me-in-production"
CRON_SECRET="change-me-in-production"
# AUTH_SECRET=""         # NextAuth secret (optional, if using NextAuth)
# NEXTAUTH_SECRET=""     # Alias for AUTH_SECRET
# CLERK_SECRET_KEY=""    # Optional — only if using Clerk auth
# RBAC_ENABLED=""        # "true" to enable role-based access control

# ---- Amazon Associates ----
# Tracking tag (affiliate ID) — generates commission for PromoSnap
AMAZON_AFFILIATE_TAG="promosnap-20"
# AMAZON_PARTNER_TAG=""  # Alias for AMAZON_AFFILIATE_TAG
# Creators API credentials (recommended — from Associates Central → Creators API)
# AMAZON_CREDENTIAL_ID=""
# AMAZON_CREDENTIAL_SECRET=""
# Legacy aliases for Creators API (backward compat)
# AMAZON_CREATORS_TOKEN=""
# AMAZON_CREATORS_SECRET=""
# PA-API 5.0 credentials (deprecated May 2026 — use Creators API instead)
# AMAZON_ACCESS_KEY=""
# AMAZON_SECRET_KEY=""

# ---- Amazon Feed Sync (optional) ----
# AMAZON_FEED_URL=""
# AMAZON_FEED_FORMAT=""      # "csv" | "json"
# AMAZON_FEED_SCHEDULE=""    # cron expression

# ---- Mercado Livre ----
MERCADOLIVRE_APP_ID=""
MERCADOLIVRE_SECRET=""
MERCADOLIVRE_REDIRECT_URI=""
MERCADOLIVRE_AFFILIATE_ID=""
# MERCADOLIVRE_AFFILIATE_WORD=""
# MERCADOLIVRE_CLIENT_ID=""    # Alias for MERCADOLIVRE_APP_ID
# MERCADOLIVRE_CLIENT_SECRET=""  # Alias for MERCADOLIVRE_SECRET

# ---- Mercado Livre OAuth (used by ML auth flow) ----
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI=""
# ML_WEBHOOK_SECRET=""   # Webhook signature verification

# ---- Mercado Livre Feed Sync (optional) ----
# ML_FEED_URL=""
# ML_FEED_FORMAT=""
# ML_FEED_SCHEDULE=""
# FF_ML_SEARCH_ENABLED=""  # "true" to enable ML search API

# ---- Shopee ----
SHOPEE_APP_ID=""
SHOPEE_SECRET=""
SHOPEE_AFFILIATE_ID=""
# SHOPEE_FEED_URL=""
# SHOPEE_FEED_FORMAT=""
# SHOPEE_FEED_SCHEDULE=""

# ---- Shein ----
SHEIN_AFFILIATE_ID=""
SHEIN_API_KEY=""
# SHEIN_FEED_URL=""
# SHEIN_FEED_FORMAT=""
# SHEIN_FEED_SCHEDULE=""

# ---- Magalu (optional) ----
# MAGALU_PARTNER_ID=""

# ---- Email (Resend) ----
# RESEND_API_KEY=""
# RESEND_FROM=""  # Default: "PromoSnap <noreply@promosnap.com.br>"

# ---- Analytics ----
NEXT_PUBLIC_GA_ID=""
# SENTRY_DSN=""

# ---- Notifications (optional) ----
# DISCORD_WEBHOOK_URL=""
# SLACK_WEBHOOK_URL=""
# VAPID_PUBLIC_KEY=""     # Web push notifications
# VAPID_PRIVATE_KEY=""

# ---- Distribution — Telegram (optional) ----
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""

# ---- Distribution — WhatsApp (optional) ----
# WHATSAPP_API_TOKEN=""
# WHATSAPP_API_URL=""
# WHATSAPP_PHONE_ID=""
# WHATSAPP_TEMPLATE_NAME=""
# WHATSAPP_GROUP_LINK=""

# ---- Ingest Configuration (optional) ----
# INGEST_BATCH_SIZE=""          # Default: 50
# INGEST_INTERVAL_MINUTES=""    # Default: 60
# INGEST_SOURCES=""             # Comma-separated: "amazon,mercadolivre,shopee,shein"
# INGEST_STRATEGY=""            # "full" | "incremental"

# ---- Image CDN (optional) ----
# Supports Cloudflare Images, Imgix, Cloudinary, etc.
# IMAGE_CDN_URL=""

# ---- Revenue Tracking (optional overrides) ----
# Default rates: Amazon 4%, ML 3%, Shopee 2.5%, Shein 3%
# REVENUE_RATES=""  # JSON override: {"amazon":0.04,"mercadolivre":0.03}

# ---- Logging ----
# LOG_LEVEL=""  # "debug" | "info" | "warn" | "error" (default: "info" in prod, "debug" in dev)

# ---- Vercel (auto-set by Vercel, do not set manually) ----
# VERCEL_ENV=""      # "production" | "preview" | "development"
# VERCEL_URL=""      # Auto-generated deployment URL
# VERCEL_REGION=""   # Deployment region

# ---- PromosApp Integration (optional) ----
# PromosApp is a promo discovery source (WhatsApp/Telegram groups), NOT a marketplace.
# FF_PROMOSAPP_ENABLED=""          # "true" to enable PromosApp ingestion pipeline
# FF_PROMOSAPP_AUTO_PUBLISH=""     # "true" to auto-publish high-confidence items (requires ENABLED)
# PROMOSAPP_WEBHOOK_SECRET=""      # Secret for webhook signature verification (HMAC-SHA256)
# PROMOSAPP_API_KEY=""             # API key for PromosApp external API (future)
# PROMOSAPP_API_URL=""             # Base URL for PromosApp API (future)

# ---- WhatsApp Auto-Ingest — Evolution API (optional) ----
# Evolution API is a self-hosted WhatsApp gateway (Railway/Docker).
# Captures messages from a WhatsApp group and processes them through the PromosApp pipeline.
# FF_WHATSAPP_AUTO_INGEST=""          # "true" to enable Evolution API webhook processing
# EVOLUTION_API_URL=""                 # Evolution API base URL (e.g., https://evo.railway.app)
# EVOLUTION_API_KEY=""                 # Global API key for Evolution API
# EVOLUTION_INSTANCE_NAME=""           # Instance name (e.g., "promosnap")
# EVOLUTION_WEBHOOK_SECRET=""          # Secret for webhook validation (static comparison)
# WHATSAPP_GROUP_JID=""               # (Legacy) Single group JID to filter
# WHATSAPP_GROUP_JIDS=""              # Comma-separated group JIDs to accept (e.g., "120363XXX@g.us,120363YYY@g.us")
#                                      # If empty, accepts ALL groups. Use this to restrict to specific groups only.

# ---- Testing (optional) ----
# PLAYWRIGHT_INSTALLED=""  # "true" if Playwright is available
