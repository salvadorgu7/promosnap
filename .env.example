# ============================================
# PromoSnap — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# ---- Database (PostgreSQL / Neon) ----
DATABASE_URL="postgresql://user:password@localhost:5432/promosnap?schema=public"

# ---- App / Domain ----
NEXT_PUBLIC_APP_URL="https://promosnap.com.br"
APP_URL="https://promosnap.com.br"
NEXT_PUBLIC_APP_NAME="PromoSnap"

# ---- Affiliate Programs ----
AMAZON_AFFILIATE_TAG=""
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_PARTNER_TAG=""

MERCADOLIVRE_APP_ID=""
MERCADOLIVRE_SECRET=""
MERCADOLIVRE_REDIRECT_URI=""
MERCADOLIVRE_AFFILIATE_ID=""

SHOPEE_APP_ID=""
SHOPEE_SECRET=""
SHOPEE_AFFILIATE_ID=""

SHEIN_AFFILIATE_ID=""
SHEIN_API_KEY=""

# ---- Mercado Livre OAuth ----
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI=""

# ---- Email (Resend) ----
RESEND_API_KEY=""
EMAIL_FROM="PromoSnap <noreply@promosnap.com.br>"

# ---- Analytics ----
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""

# ---- Admin ----
ADMIN_SECRET="change-me-in-production"

# ---- Cron (Vercel Cron) ----
CRON_SECRET="change-me-in-production"

# ---- Revenue Tracking (optional overrides) ----
# Default rates: Amazon 4%, ML 3%, Shopee 2.5%, Shein 3%
# REVENUE_RATE_AMAZON=0.04
# REVENUE_RATE_ML=0.03
# REVENUE_RATE_SHOPEE=0.025
# REVENUE_RATE_SHEIN=0.03
