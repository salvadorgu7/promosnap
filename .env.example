# ============================================
# PromoSnap — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/promosnap?schema=public"

# Redis (optional, for cache/jobs)
REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PromoSnap"

# Affiliate Programs
AMAZON_AFFILIATE_TAG=""
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_PARTNER_TAG=""

MERCADOLIVRE_APP_ID=""
MERCADOLIVRE_SECRET=""
MERCADOLIVRE_REDIRECT_URI=""
MERCADOLIVRE_AFFILIATE_ID=""

SHOPEE_APP_ID=""
SHOPEE_SECRET=""
SHOPEE_AFFILIATE_ID=""

SHEIN_AFFILIATE_ID=""
SHEIN_API_KEY=""

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""

# Admin
ADMIN_SECRET="change-me-in-production"
